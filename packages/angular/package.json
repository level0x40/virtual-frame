{
  "name": "@virtual-frame/angular",
  "version": "0.1.0",
  "description": "Angular directive for Virtual Frame",
  "homepage": "https://virtual-frame.level0x40.com",
  "bugs": {
    "url": "https://github.com/level0x40/virtual-frame/issues"
  },
  "license": "LicenseRef-SAL-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/level0x40/virtual-frame.git",
    "directory": "packages/angular"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/virtual-frame-angular.mjs"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "default": "./dist/fesm2022/virtual-frame-angular-store.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepack": "cp ../../LICENSE LICENSE",
    "build": "ng-packagr -p ng-package.json && rm -f dist/package.json && find dist -name '*.map' -delete",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "^20.2.0",
    "@virtual-frame/store": "workspace:^",
    "ng-packagr": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "virtual-frame": "workspace:^"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "@virtual-frame/store": "workspace:^",
    "virtual-frame": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@virtual-frame/store": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
