{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "target": "ES2022",
    "paths": { "~/*": ["./src/*"] },
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
